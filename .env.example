DATABASE_URL="postgresql://customerspeed:customerspeed@localhost:5544/customerspeed?schema=public"
NODE_ENV=
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""              # RICHIESTO, min 32 char — genera con: openssl rand -base64 32
APP_URL="http://localhost:3000" # base URL per i link in email (verifica/reset)

# Tenant PIATTAFORMA neutro (NON un tenant cliente): slug dell'Organization che possiede
# branding/marketing pubblico, i consensi cookie dei visitatori anonimi e il login di default
# del superAdmin. Il seed lo crea come "customerspeed". NON puntarlo a un tenant cliente reale
# (es. "fabio"): i tenant cliente si raggiungono via slug esplicito (/login?org=fabio) o, in
# futuro, via sottodominio/custom domain.
DEFAULT_ORG_SLUG="customerspeed"

# ─────────────────────────────────────────────────────────────────────────────
# Basic Auth (gate temporaneo "accesso riservato" davanti a TUTTO il sito)
# ─────────────────────────────────────────────────────────────────────────────
# Attivo SOLO se ENTRAMBE sono valorizzate (così il locale non viene bloccato).
# Mostra il prompt utente/password del browser prima di qualsiasi pagina; è una
# barriera grossolana per tenere fuori estranei/crawler mentre il deploy è privato.
# L'auth applicativa (login/RBAC/tenant) resta la sicurezza vera sottostante.
# Per rendere il sito pubblico: rimuovi queste due variabili (nessuna modifica al codice).
# BASIC_AUTH_USER="fabio"
# BASIC_AUTH_PASSWORD=""          # scegli una password robusta; impostala solo in Vercel

# reCAPTCHA v3 (opzionale in dev: la verifica fa no-op se le chiavi sono assenti).
# La SITE key è pubblica (client, prefisso NEXT_PUBLIC_); la SECRET key è server-side.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""
# RECAPTCHA_MIN_SCORE="0.5"      # soglia v3 (default 0.5)

# reCAPTCHA v2 — casella "Non sono un robot" (fallback quando lo score v3 è basso).
# Coppia di chiavi DIVERSA dalla v3: una site key v3 non rende il widget v2 e
# viceversa. Opzionali: se la SECRET v2 è assente il fallback è disattivato e uno
# score v3 basso viene semplicemente rifiutato (comportamento attuale, nessuna
# regressione). La SITE key è pubblica (client); la SECRET è server-side.
# NEXT_PUBLIC_RECAPTCHA_V2_SITE_KEY=""
# RECAPTCHA_V2_SECRET_KEY=""

# Email transazionale (opzionale in dev → logging sender)
# RESEND_API_KEY=""
# EMAIL_FROM="CustomerSpeed <no-reply@example.com>"

# ─────────────────────────────────────────────────────────────────────────────
# Integrazioni calendario (Fase 6 — OPZIONALI, gated dal feature flag tenant
# `calendarIntegrations`; OFF per Fabio). Senza queste chiavi il modulo degrada
# con grazia: i pulsanti "Collega" mostrano "Non configurato", nessun crash.
# Nessun segreto reale nel repo: valorizzare solo nell'ambiente (Vercel).
# ─────────────────────────────────────────────────────────────────────────────

# Chiave AES-256-GCM per cifrare a riposo i token di terze parti
# (CalendarConnection.accessToken/refreshToken). Deve decodificare a ESATTAMENTE
# 32 byte (base64 consigliato, hex accettato). Genera con: openssl rand -base64 32
# Richiesta a runtime solo quando si usano le integrazioni; mai loggata.
ENCRYPTION_KEY=""

# Google Calendar OAuth2 (credenziali "Web application").
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/integrations/google/callback"

# Calendly OAuth2 + firma webhook.
CALENDLY_CLIENT_ID=""
CALENDLY_CLIENT_SECRET=""
CALENDLY_REDIRECT_URI="http://localhost:3000/api/integrations/calendly/callback"
# Chiave di firma del webhook Calendly (verifica `Calendly-Webhook-Signature`).
CALENDLY_WEBHOOK_SIGNING_KEY=""

# ─────────────────────────────────────────────────────────────────────────────
# Rate limiting (Fase 8 hardening — docs/06 §6.1)
# ─────────────────────────────────────────────────────────────────────────────
# Backend del rate limiter condiviso per gli endpoint auth (login/register/forgot).
#   memory (default) → fixed-window process-local: ok per singola istanza / dev.
#   redis            → store distribuito (Upstash/Redis). L'interfaccia RateLimiter
#                      è già pronta: per abilitarlo, implementa un adapter su
#                      RATE_LIMIT_REDIS_URL in src/lib/rate-limit.ts (oggi: warning
#                      + fallback in-memory finché l'adapter non è cablato).
# RATE_LIMIT_BACKEND="memory"
# RATE_LIMIT_REDIS_URL=""
# Kill-switch: se "true" DISATTIVA il rate limit (limiter no-op). Serve SOLO ai test
# e2e per martellare il login senza incappare nel limite per-IP. DEVE restare
# assente/false in produzione: parseEnv RIFIUTA RATE_LIMIT_DISABLED=true quando
# NODE_ENV=production (fail-safe). Default: false.
# RATE_LIMIT_DISABLED="false"
# Segnale e2e: SOLO la suite Playwright lo imposta (gira su un BUILD di produzione)
# per far passare RATE_LIMIT_DISABLED attraverso il fail-safe. Un deploy reale NON
# deve MAI valorizzarlo. Default: assente.
# E2E="false"

# ─────────────────────────────────────────────────────────────────────────────
# Observability / Sentry (Fase 8 — OPZIONALE, no-op se assente)
# ─────────────────────────────────────────────────────────────────────────────
# Senza SENTRY_DSN il layer di observability è un NO-OP: nessuna rete, nessun crash.
# Per attivarlo al setup infra: installa `@sentry/nextjs`, cabla createReporter()/
# initObservability() in src/lib/observability.ts, poi valorizza il DSN (+ il mirror
# pubblico per il browser). Vedi la checklist in README / docs/06 §6.4.
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_TRACES_SAMPLE_RATE="0"   # 0..1 — tienilo basso in prod (volume/costo)
# SENTRY_ENVIRONMENT=""           # etichetta logica (default: NODE_ENV)
