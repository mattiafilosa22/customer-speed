# ─────────────────────────────────────────────
# CustomerSpeed — variabili d'ambiente (esempio)
# Copia in .env.local e compila. NON committare .env*
# ─────────────────────────────────────────────

# Database (PostgreSQL — locale via docker-compose, oppure Neon/Supabase region EU)
# Le credenziali locali combaciano con docker-compose.yml (servizio "db").
DATABASE_URL="postgresql://customerspeed:customerspeed@localhost:5432/customerspeed?schema=public"

# Auth.js / NextAuth v5
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""              # genera con: openssl rand -base64 32

# Cifratura token di terze parti (Google/Calendly) a riposo
ENCRYPTION_KEY=""               # 32 byte base64: openssl rand -base64 32

# Google reCAPTCHA (v3 + fallback v2)
RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# Google OAuth (login + Google Calendar) — opzionale per Fabio
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Calendly (modulo opzionale)
CALENDLY_CLIENT_ID=""
CALENDLY_CLIENT_SECRET=""
CALENDLY_WEBHOOK_SIGNING_KEY=""

# Email transazionali (Resend o SMTP)
RESEND_API_KEY=""

# Region preferita (data residency UE)
APP_REGION="eu"
