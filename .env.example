DATABASE_URL="postgresql://customerspeed:customerspeed@localhost:5432/customerspeed?schema=public"
NODE_ENV=
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""              # RICHIESTO, min 32 char — genera con: openssl rand -base64 32
APP_URL="http://localhost:3000" # base URL per i link in email (verifica/reset)

# Tenant PIATTAFORMA neutro (NON un tenant cliente): slug dell'Organization che possiede
# branding/marketing pubblico, i consensi cookie dei visitatori anonimi e il login di default
# del superAdmin. Il seed lo crea come "customerspeed". NON puntarlo a un tenant cliente reale
# (es. "fabio"): i tenant cliente si raggiungono via slug esplicito (/login?org=fabio) o, in
# futuro, via sottodominio/custom domain.
DEFAULT_ORG_SLUG="customerspeed"

# reCAPTCHA v3 (opzionale in dev: la verifica fa no-op se le chiavi sono assenti).
# La SITE key è pubblica (client, prefisso NEXT_PUBLIC_); la SECRET key è server-side.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""
# RECAPTCHA_MIN_SCORE="0.5"      # soglia v3 (default 0.5)

# Email transazionale (opzionale in dev → logging sender)
# RESEND_API_KEY=""
# EMAIL_FROM="CustomerSpeed <no-reply@example.com>"
